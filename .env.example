# EmberArmor — Environment Variables
# Copy to .env and fill in real values before starting the server.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# REQUIRED — system refuses to start without these
# ---------------------------------------------------------------------------

# Master API key for authenticating calls to EmberArmor endpoints (>= 32 chars)
EMBER_API_KEY=your-api-key-here-must-be-32-chars-minimum

# Secret key for token signing (>= 32 chars)
EMBER_TOKEN_SECRET=your-token-secret-here-must-be-32-chars

# ---------------------------------------------------------------------------
# SONAR (Perplexity) — Load-bearing live threat intelligence
# ---------------------------------------------------------------------------
# Perplexity API key for Sonar real-time web intelligence.
# Required for the SonarConsensusAgent to vote in the EnsembleConductor.
# Without this, the system falls back to local-only consensus (fail-closed).
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key-here

# Sonar model to use (sonar-pro recommended for real-time grounded responses)
EMBER_SONAR_MODEL=sonar-pro

# Set to false to disable Sonar entirely (local-only consensus fallback)
EMBER_SONAR_ENABLED=true

# Voting weight for Sonar in the EnsembleConductor (0.0–1.0)
EMBER_SONAR_AGENT_WEIGHT=0.40

# ---------------------------------------------------------------------------
# APPLICATION (optional — defaults shown)
# ---------------------------------------------------------------------------
EMBER_HOST=127.0.0.1
EMBER_PORT=8000
EMBER_DEBUG=false
EMBER_LOG_LEVEL=INFO
EMBER_STRUCTURED_LOGGING=true

# ---------------------------------------------------------------------------
# RATE LIMITING
# ---------------------------------------------------------------------------
EMBER_RATE_LIMIT_REQUESTS=60
EMBER_RATE_LIMIT_WINDOW=60

# ---------------------------------------------------------------------------
# CIRCUIT BREAKER
# ---------------------------------------------------------------------------
EMBER_CB_FAILURE_THRESHOLD=5
EMBER_CB_RECOVERY_TIMEOUT=30.0
